{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Finding",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "severity",
    "file",
    "line",
    "description",
    "suggestion"
  ],
  "properties": {
    "severity": {
      "type": "string",
      "enum": ["critical", "warning", "info"]
    },
    "file": {
      "type": "string"
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string"
    },
    "suggestion": {
      "type": "string"
    },
    "cwe": {
      "type": "string"
    },
    "impact": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "attack_scenario": {
      "type": "string"
    }
  }
}
