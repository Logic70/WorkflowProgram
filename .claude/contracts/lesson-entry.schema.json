{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lesson Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "date",
    "command",
    "issue_type",
    "severity",
    "status",
    "extract_to_rule",
    "follow_up_owner"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^lesson-[a-z0-9-]+$"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "command": {
      "type": "string"
    },
    "issue_type": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "warning", "info"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "done", "wont_fix"]
    },
    "extract_to_rule": {
      "type": "boolean"
    },
    "follow_up_owner": {
      "type": "string"
    }
  }
}
