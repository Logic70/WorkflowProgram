{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Validation Report Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "date",
    "status",
    "scope",
    "command",
    "result",
    "notes"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "WARN"]
    },
    "scope": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "result": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
